---
interface Props {
  code: string;
}
const { code } = Astro.props;
---
<div class="my-8 w-full overflow-x-auto rounded-lg border border-vp-border bg-vp-input flex justify-center py-8 px-4">
  <pre class="mermaid text-center m-0 bg-transparent text-sm">
    {code}
  </pre>
</div>

<script>
  import mermaid from 'mermaid';
  
  function initMermaid() {
    const isLight = document.documentElement.classList.contains('light');
    mermaid.initialize({ 
      startOnLoad: false, 
      theme: isLight ? 'default' : 'dark',
      fontFamily: '"DM Sans", ui-sans-serif, system-ui, sans-serif'
    });
    mermaid.run({
      querySelector: '.mermaid'
    });
  }

  // Run on first load
  document.addEventListener('DOMContentLoaded', initMermaid);
  // Run on page change
  document.addEventListener('astro:page-load', initMermaid);
  // Re-run if theme changes
  window.addEventListener('theme-changed', initMermaid);
</script>
