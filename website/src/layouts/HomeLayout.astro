---
import Layout from './Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';

let version = '0.1.0';
try {
  const res = await fetch('https://api.github.com/repos/shantoislamdev/shellwire/releases/latest');
  if (res.ok) {
    const data = await res.json();
    if (data && data.tag_name) {
      const tag = data.tag_name;
      version = tag.startsWith('v') ? tag.slice(1) : tag;
    }
  }
} catch (e) {
  // Silent fallback
}

const tagVersion = `v${version}`;
---

<Layout>
  <div class="min-h-screen bg-vp-bg text-vp-fg font-sans antialiased flex flex-col items-center">
    <div class="flex w-full max-w-[1200px] px-4 sm:px-6 flex-1 items-start">
      <main class="flex-1 w-full min-w-0 py-8 md:py-12 md:px-8 lg:px-12 transition-all duration-300 ease-in-out opacity-100">
        <div class="max-w-[800px] mx-auto w-full">
          <header class="mb-16 sm:mb-20">
            <div class="flex items-center gap-3 sm:gap-4 mb-2">
              <h1 class="text-xl sm:text-2xl font-medium tracking-tight text-vp-fg">Shellwire</h1>
            </div>
            <p class="text-vp-text text-[15px] sm:text-base leading-relaxed">A WebSocket daemon for remote shell execution and interactive terminal sessions.</p>
            
            <div class="mt-6 flex flex-wrap items-center justify-between text-sm">
              <div class="flex items-center gap-6">
                <a href="https://github.com/shantoislamdev/shellwire" class="text-vp-subtle hover:text-vp-highlight transition-colors">GitHub</a>
                <a href="/documentation/overview" class="text-vp-subtle hover:text-vp-highlight transition-colors">Documentation</a>
                <span class="text-vp-subtle">{tagVersion}</span>
              </div>
              <ThemeToggle />
            </div>
          </header>
          
          <div class="home-prose prose-vp max-w-none font-sans text-[15px] leading-[1.65] text-vp-fg antialiased">
            <slot />
          </div>

          <Footer className="mt-12 mb-12" />
        </div>
      </main>
    </div>
  </div>
</Layout>
